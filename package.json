    "clsx": "^2.1.1",
    "geist": "^1.3.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.12.1",
    "next": "16.2.5",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
