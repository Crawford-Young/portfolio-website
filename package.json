{
  "name": "crawford-young-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "lint": "eslint . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "prepare": "husky"
