    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@crawfordyoung/ui": "^0.12.0",
    "@sentry/nextjs": "^10.58.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "brace-expansion": "5.0.6",
